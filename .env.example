APP_NAME=CrossSwap
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — uncomment the connection you want and fill in credentials.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=crossswap
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis  # recommended for production with Horizon

CACHE_STORE=database
# CACHE_STORE=redis

# Redis (optional — recommended for Horizon + cache)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — set up to receive ticket and receipt emails on your customers' behalf.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ChangeNOW partner API key — generate one at https://changenow.io/affiliate.
# Optional referral code lets you stack the volume against your partner balance.
CHANGENOW_API_KEY=
CHANGENOW_REFERRAL=

# Internal debug toolbar — leave OFF in production.
DEBUGBAR_ENABLED=false

# The marketing /preview page is only shown on the official demo site.
# Leave false in production installs.
SHOW_PREVIEW=false

VITE_APP_NAME="${APP_NAME}"
# Enable Content-Security-Policy headers — leave false until you've verified
# nothing on your install breaks. Recommended after launch.
CSP_ENABLED=false
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
