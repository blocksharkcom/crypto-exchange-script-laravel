{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "ordered_imports": {
            "sort_algorithm": "alpha",
            "imports_order": ["class", "function", "const"]
        },
        "single_quote": true,
        "no_unused_imports": true,
        "global_namespace_import": {
            "import_classes": false,
            "import_constants": false,
            "import_functions": false
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor",
        "config",
        "database/migrations"
    ]
}
